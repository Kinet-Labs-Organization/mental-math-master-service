generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                 @id @default(autoincrement())
  email                  String              @unique
  password               String?
  subscribedOn           DateTime?
  subscriptionExpiration DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  name                   String?
  SignUpMethod           SignUpMethod        @default(GMAIL)
  country                String?
  term                   Term?               @default(d7)
  status                 SubscriptionStatus? @default(TRIAL)
  lastSubscriptionStatus SubscriptionStatus?
  gameActivities         GameActivity[]
  notifications          Notifications[]
  report                 Report?
}

model Report {
  id           Int           @id @default(autoincrement())
  gamesPlayed  Int           @default(0)
  accuracy     Float         @default(0)
  streak       Int           @default(0)
  score        Int           @default(0)
  userId       Int           @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  achievements Achievement[]
  user         User          @relation(fields: [userId], references: [id])
}

model GameActivity {
  id             Int      @id @default(autoincrement())
  gameId         String
  gameType       String
  correctAnswers Int
  wrongAnswers   Int
  playedAt       DateTime
  userId         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  score          Int?
  user           User     @relation(fields: [userId], references: [id])
}

model Notifications {
  id             Int      @id @default(autoincrement())
  notificationId String
  gameType       String
  correctAnswers Int
  wrongAnswers   Int
  playedAt       DateTime
  userId         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])
}

model Blogs {
  id        Int      @id @default(autoincrement())
  brief     String   @default("New blog post about mental math !")
  icon      String   @default("")
  image     String   @default("https://images.unsplash.com/photo-1509228627152-72ae9ae6848d")
  link      String   @default("https://www.mentalup.co/blog/mental-math")
  read      String   @default("8 min")
  title     String   @default("What Is Mental Math and Why It Matters")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SignUpMethod {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
  GMAIL
}

enum Role {
  SYSTEM
  ADMIN
  NORMAL
}

enum SubscriptionStatus {
  UNSUBSCRIBED
  TRIAL
  PRO
}

enum Achievement {
  PLAY_STREAK_3
  PLAY_STREAK_7
  PLAY_STREAK_22
  PLAY_STREAK_30
  WIN_STREAK_3
  WIN_STREAK_5
  WIN_STREAK_10
  GAMES_TOTAL_25
  GAMES_TOTAL_50
  GAMES_TOTAL_100
  GAMES_TOTAL_200
  GAMES_TOTAL_500
  GAMES_TOTAL_1000
  SCORE_TOTAL_500
  SCORE_TOTAL_1000
  SCORE_TOTAL_2000
  SCORE_TOTAL_5000
  SCORE_TOTAL_10000
}

enum Term {
  d7
  d30
  d365
}
